# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=production
APP_PORT=8080
FRONTEND_URL=https://your-domain.com

# ─── Security ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace_me_with_openssl_rand_hex_32
ENCRYPTION_KEY=replace_me_with_exactly_32_byte_secret_

# ─── Database / Redis ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://mmo:CHANGE_ME_strong_postgres_password@host.docker.internal:5432/mmo?sslmode=disable
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@host.docker.internal:6379

# ─── Deployment ───────────────────────────────────────────────────────────────
IMAGE_OWNER=ngthotuan
APP_VERSION=1.0.0

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mmo-media
R2_PUBLIC_URL=

# ─── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# AI provider: gemini | mock  (mock = deterministic, no network — hermetic tests)
AI_PROVIDER=gemini
AI_FALLBACK_TO_MOCK=true
GEMINI_MODEL=gemini-2.5-flash

# ─── Pipeline / publishing ──────────────────────────────────────────────────────
# When true, ALL publishes are mocked (no real social API calls). A per-channel
# dry_run flag also exists. Use for end-to-end testing without real OAuth.
PUBLISH_DRY_RUN=false

# ─── Media APIs ───────────────────────────────────────────────────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=

# ─── Social Media ─────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# YouTube Shorts publishing (Google OAuth2 — separate from YOUTUBE_API_KEY above)
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
YOUTUBE_PRIVACY_STATUS=unlisted

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace_me_with_openssl_rand_hex_32
