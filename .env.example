# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
FRONTEND_URL=http://localhost:3000

# ─── Security (generate strong random values for production) ──────────────────
JWT_SECRET=change_me_in_production_please
ENCRYPTION_KEY=change_me_32_bytes_key_in_prod!!   # Must be exactly 32 chars

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://mmo:mmo_dev_password@localhost:5432/mmo?sslmode=disable

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Cloudflare R2 Storage ────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=mmo-media
R2_PUBLIC_URL=                                    # e.g. https://cdn.yourdomain.com

# ─── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                                   # Google AI Studio — free 1500 req/day

# ─── Media APIs (free) ────────────────────────────────────────────────────────
PEXELS_API_KEY=                                   # pexels.com/api — free
PIXABAY_API_KEY=                                  # pixabay.com/api — free
YOUTUBE_API_KEY=                                  # Google Cloud Console — free 10k units/day

# ─── Social Media ─────────────────────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_in_production
